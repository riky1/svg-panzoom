{
  "name": "@riky1/svg-panzoom",
  "version": "1.1.10",
  "description": "Framework-agnostic SVG zoom & pan for inline SVG elements.",
  "type": "module",
  "author": "riky1 (Riccardo Cresti)",
  "license": "MIT",
  "keywords": [
    "svg",
    "pan",
    "zoom",
    "panzoom",
    "pan zoom",
    "svg pan zoom",
    "wheel",
    "pointer-events",
    "vue pan zoom",
    "react pan zoom"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riky1/svg-panzoom.git"
  },
  "homepage": "https://github.com/riky1/svg-panzoom",
  "bugs": {
    "url": "https://github.com/riky1/svg-panzoom/issues"
  },
  "main": "./dist/svg-panzoom.cjs",
  "module": "./dist/svg-panzoom.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/svg-panzoom.js",
      "require": "./dist/svg-panzoom.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "build:demo": "BUILD_MODE=demo vite build --config vite.config.js",
    "dev:demo": "BUILD_MODE=demo vite --config vite.config.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "jsdom": "^24.0.0",
    "sass": "^1.78.0",
    "vite": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
